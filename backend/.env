# ============================================
# Smart Waste Management — Backend Environment
# ============================================
# DO NOT commit this file to git.
# Add .env to your .gitignore if not already there.

# ── Environment ──────────────────────────────
ENVIRONMENT=development

# ── API Server ───────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Security ─────────────────────────────────
# Generate a strong key for production with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-before-production-use-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ─────────────────────────────────
# SQLite for now — swap to PostgreSQL before deploying:
#   DATABASE_URL=postgresql://user:password@localhost:5432/smart_waste
DATABASE_URL=postgresql://waste_user:Sujal123@localhost:5432/smart_waste

# ── CORS ─────────────────────────────────────
# Your Next.js frontend on localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO

# ── ML Settings ──────────────────────────────
ML_ENABLED=true
ML_SENSITIVITY=2.5
ML_FILL_PREDICTION_THRESHOLD=80
ML_COLLECTION_CONFIDENCE_MIN=0.5

# ── Firebase Admin SDK ───────────────────────
# Path to the service account JSON you downloaded.
# File must be in your backend/ folder.
# NEVER commit firebase-service-account.json to git.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Your Firebase project ID — used to validate that tokens
# were issued for YOUR project, not someone else's.
FIREBASE_PROJECT_ID=sgm-project-fc254

# ── IoT API Keys ─────────────────────────────
API_KEY_PREFIX=wsk_live_

