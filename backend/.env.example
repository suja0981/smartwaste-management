# ============================================================
# Smart Waste Management — Backend Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values below
#   3. Never commit .env to git — it's already in .gitignore
# ============================================================

# ── Environment ──────────────────────────────────────────────
# development | production | test
ENVIRONMENT=development

# ── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Security ─────────────────────────────────────────────────
# REQUIRED: Generate a strong secret key and paste it here.
# Run this command to generate one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-generated-secret-key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────
# REQUIRED: PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database_name>
#
# Local development (after running docker-compose.postgresql.yml):
#   DATABASE_URL=postgresql://waste_user:waste_password_dev@localhost:5432/smart_waste
#
# Production (example for a hosted DB like Supabase, Railway, Render):
#   DATABASE_URL=postgresql://user:password@db.example.com:5432/smart_waste
DATABASE_URL=postgresql://waste_user:waste_password_dev@localhost:5432/smart_waste

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your deployed frontend URL here in production.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── ML Settings ──────────────────────────────────────────────
ML_ENABLED=true
ML_SENSITIVITY=2.5
ML_FILL_PREDICTION_THRESHOLD=80
ML_COLLECTION_CONFIDENCE_MIN=0.5

# ── Firebase Admin SDK ───────────────────────────────────────
# Option A — Point to a local JSON file (simpler for development):
#   1. Go to Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key" → download the JSON
#   3. Save it as backend/firebase-service-account.json
#   4. Set the path below (NEVER commit that JSON file to git)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Your Firebase project ID (shown in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Option B — Paste the entire JSON as a string (better for Docker / cloud):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── IoT API Keys ─────────────────────────────────────────────
# REQUIRED: API key that IoT devices use to push telemetry.
# Generate one with:
#   python -c "import secrets; print('wsk_live_' + secrets.token_urlsafe(32))"
IOT_API_KEY=wsk_live_replace-this-with-a-generated-iot-key
