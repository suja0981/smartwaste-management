# Smart Waste Management System - Environment Configuration
# Copy this file to .env and fill in the actual values for your environment

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
# Options: development, production, staging

# ============================================
# API SERVER SETTINGS
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
# Set API_RELOAD=false in production

# ============================================
# SECURITY - CHANGE THESE IN PRODUCTION
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# DATABASE
# ============================================
# SQLite (default for local development)
# DATABASE_URL=sqlite:///./smart_waste.db

# PostgreSQL (local development - recommended)
DATABASE_URL=postgresql://waste_user:waste_password_dev@localhost:5432/smart_waste

# PostgreSQL with psycopg3 (faster, newer)
# DATABASE_URL=postgresql+psycopg://waste_user:waste_password_dev@localhost:5432/smart_waste

# AWS RDS PostgreSQL
# DATABASE_URL=postgresql://admin:password@smart-waste.xxxxx.us-east-1.rds.amazonaws.com:5432/smart_waste

# Azure Database for PostgreSQL
# DATABASE_URL=postgresql://admin@smart-waste:password@smart-waste.postgres.database.azure.com:5432/smart_waste

# DigitalOcean Managed Database
# DATABASE_URL=postgresql://doadmin:password@db-xxx-do-user-xxx.b.db.ondigitalocean.com:25060/smart_waste

# ============================================
# CORS - ALLOWED ORIGINS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080
# Production example: https://yourdomain.com,https://api.yourdomain.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# ML SETTINGS
# ============================================
ML_ENABLED=true
ML_SENSITIVITY=2.5
# Anomaly detection sensitivity (higher = stricter)
ML_FILL_PREDICTION_THRESHOLD=80
# Percentage threshold for collection recommendation
ML_COLLECTION_CONFIDENCE_MIN=0.5
# Minimum confidence level for predictions

# ============================================
# FEATURE FLAGS
# ============================================
# Add feature flags here if needed
# ANALYTICS_ENABLED=true
# NOTIFICATIONS_ENABLED=true
