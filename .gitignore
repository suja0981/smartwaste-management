# ============================================================
# Smart Waste Management — Root .gitignore
# ============================================================

# ── Secrets & credentials ────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
backend/firebase-service-account.json
*-service-account.json
*.pem
*.key
*.p12

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ── Database files ───────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Next.js / Node ───────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── IDE / editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn

# ── OS artifacts ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker override ──────────────────────────────────────────
docker-compose.override.yml

# ── Build / dist ─────────────────────────────────────────────
dist/
build/
*.egg-info/
.eggs/
